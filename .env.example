# Optional — enables persistence, audit, webhooks, dashboard, full-text search.
# The app auto-creates all its tables on the first request (idempotent migration).
#
# Neon (recommended, free tier):
#   https://neon.tech → create project → Connection string → paste here.
#   Example: postgres://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
#
# Supabase:
#   Project Settings → Database → Connection string (URI).
#   Use the pooler connection on port 6543 for Vercel serverless compatibility.
#   Example: postgres://postgres.xxxx:pass@aws-0-us-east-1.pooler.supabase.com:6543/postgres
#
# Local Postgres:
#   createdb mailchecker
#   postgres://postgres:password@localhost:5432/mailchecker
#
# The database name at the end of the URL must already exist on the server.
# The "db" placeholder in the template below WILL fail — replace it.
DATABASE_URL=

# Default gofile.io credentials (users can still override in the UI).
GOFILE_TOKEN=Vlgj7YMQ9wNLJKOGdnJoycIfRxS8sSkY
GOFILE_FOLDER_ID=

# Deliverability providers (optional).
MAILTESTER_TOKEN=
GLOCKAPPS_KEY=
